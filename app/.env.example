# Ortam değişkenleri örneği — kopyala: `cp .env.example .env`
# Yalnızca VITE_ önekli değişkenler istemciye (tarayıcıya) gönderilir.
# Doğrulama ve varsayılanlar: src/lib/env.ts

# API taban adresi (şu an sahte servis katmanı kullanılıyor — roadmap 0.2/2.1).
VITE_API_URL=/api

# Sahte servis katmanının yapay gecikmesi (ms). Loading state'lerini test etmek için.
VITE_API_DELAY_MS=450

# Sahte isteklerin hata verme olasılığı [0..1]. Hata UX'ini denemek için 0.2 gibi ver.
VITE_API_ERROR_RATE=0

# Dağıtım hedefi: development | staging | production
VITE_APP_ENV=development
